{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    "packages/loopover-mcp": {
      "release-type": "node",
      "component": "mcp",
      "package-name": "@loopover/mcp"
    },
    "packages/loopover-engine": {
      "release-type": "node",
      "component": "engine",
      "package-name": "@loopover/engine"
    },
    "packages/loopover-miner": {
      "release-type": "node",
      "component": "miner",
      "package-name": "@loopover/miner"
    },
    "packages/loopover-ui-kit": {
      "release-type": "node",
      "component": "ui-kit",
      "package-name": "@loopover/ui-kit"
    }
  },
  "include-component-in-tag": true,
  "separate-pull-requests": true,
  "pull-request-title-pattern": "chore(release): cut${component} v${version}",
  "always-link-local": false,
  "plugins": [
    {
      "type": "node-workspace",
      "merge": false
    }
  ],
  "changelog-sections": [
    { "type": "feat", "section": "Features" },
    { "type": "fix", "section": "Fixes" },
    { "type": "perf", "section": "Performance" },
    { "type": "deps", "section": "Dependencies" },
    { "type": "revert", "section": "Reverts" },
    { "type": "docs", "section": "Docs", "hidden": true },
    { "type": "refactor", "section": "Refactors", "hidden": true },
    { "type": "test", "section": "Tests", "hidden": true },
    { "type": "build", "section": "Build", "hidden": true },
    { "type": "ci", "section": "CI", "hidden": true },
    { "type": "style", "section": "Styles", "hidden": true },
    { "type": "chore", "section": "Chores", "hidden": true }
  ]
}
